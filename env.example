# ─────────────────────────────────────────────────────────────────
#  ReLoop — Environment Variables
#  Copy this file to .env.local for local dev (never commit that file)
#  On Vercel: add these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Required for live backend ─────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Without these vars ────────────────────────────────────────────
# The app runs in demo mode with 30 pre-loaded listings.
# Auth, real listings, and chat require a Supabase project.
